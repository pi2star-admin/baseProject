// Prisma Schema
// 运行 `prisma db pull` 可从现有数据库反向生成模型
// 运行 `prisma generate` 生成 PrismaClient

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

